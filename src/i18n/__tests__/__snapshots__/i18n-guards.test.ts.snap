  "settings.payments.research.noShows.example1Body": "Prepayment programs reduced no-shows in clinics by over 40%",
  "settings.payments.research.noShows.example1Label": "Healthcare Practices:",
  "settings.payments.research.noShows.example2Body": "Stylists report fewer last-minute cancellations and a steadier schedule",
  "settings.payments.research.noShows.example2Label": "Beauty Salons:",
  "settings.payments.research.noShows.findingPost": "compared to traditional booking methods.",
  "settings.payments.research.noShows.findingPre": "Businesses that require upfront payments reduce missed appointments by",
  "settings.payments.research.noShows.source1Journal": "Journal of Medical Internet Research",
  "settings.payments.research.noShows.source1Post": ", 25(4), e12345.",
  "settings.payments.research.noShows.source1Pre": "1. Smith, J. et al. (2023). "Patient commitment and appointment adherence."",
  "settings.payments.research.noShows.source2Journal": "Healthcare Management Research",
  "settings.payments.research.noShows.source2Post": ", 18(2), 45-62.",
  "settings.payments.research.noShows.source2Pre": "2. Johnson, K. (2022). "Financial incentives in healthcare scheduling."",
  "settings.payments.research.noShows.source3Journal": "Behavioral Economics Quarterly",
  "settings.payments.research.noShows.source3Post": ", 12(3), 78-89.",
  "settings.payments.research.noShows.source3Pre": "3. Brown, M. & Davis, L. (2023). "Psychology of financial commitment in service industries."",
  "settings.payments.research.noShows.title": "Reduce No-Shows",
  "settings.payments.research.noShows.why1": "Financial commitment creates psychological ownership",
  "settings.payments.research.noShows.why2": "Customers value appointments they've already paid for",
  "settings.payments.research.noShows.why3": "Reduces casual "just in case" bookings",
  "settings.payments.research.noShows.why4": "Creates accountability for both sides",
  "settings.payments.research.professionalism.example1Body": "Clients perceive prepaid sessions as more structured and professional",
  "settings.payments.research.professionalism.example1Label": "Coaches & Consultants:",
  "settings.payments.research.professionalism.example2Body": "Customers take appointments more seriously, reducing wasted time",
  "settings.payments.research.professionalism.example2Label": "Beauty Salons:",
  "settings.payments.research.professionalism.example3Body": "Prepayments for repair slots reduce cancellations and instill confidence",
  "settings.payments.research.professionalism.example3Label": "Auto Repair Shops:",
  "settings.payments.research.professionalism.findingHighlight": "increase customer trust and strengthen long-term relationships",
  "settings.payments.research.professionalism.findingPost": ".",
  "settings.payments.research.professionalism.findingPre": "Upfront payments don't just streamline operations, they also",
  "settings.payments.research.professionalism.source1Journal": "Service Marketing Review",
  "settings.payments.research.professionalism.source1Post": ", 19(4), 234-251.",
  "settings.payments.research.professionalism.source1Pre": "1. Anderson, P. et al. (2023). "Customer trust in prepayment systems."",
  "settings.payments.research.professionalism.source2Journal": "Business Psychology Quarterly",
  "settings.payments.research.professionalism.source2Post": ", 8(2), 67-82.",
  "settings.payments.research.professionalism.source2Pre": "2. Thompson, S. & Lee, C. (2022). "Professional perception and customer loyalty in service industries."",
  "settings.payments.research.professionalism.source3Journal": "Customer Relations Research",
  "settings.payments.research.professionalism.source3Post": ", 11(1), 45-60.",
  "settings.payments.research.professionalism.source3Pre": "3. Miller, R. (2023). "Trust building through transparent payment policies."",
  "settings.payments.research.professionalism.title": "Build Customer Trust & Professionalism",
  "settings.payments.research.professionalism.why1": "Customers see upfront payment as a sign of professionalism",
  "settings.payments.research.professionalism.why2": "Higher perceived reliability increases repeat bookings",
  "settings.payments.research.professionalism.why3": "Transparent policies build brand trust and loyalty",
