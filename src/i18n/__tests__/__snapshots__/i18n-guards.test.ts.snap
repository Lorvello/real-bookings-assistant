  "terms.s1.h": "1. Acceptance of terms",
  "terms.s1.p": "By using our calendar booking service, you agree to these terms of service. If you do not agree to these terms, you may not use our service.",
  "terms.s10.h": "10. Changes",
  "terms.s10.p": "We reserve the right to modify these terms. Changes will take effect 30 days after notification via email or through our website.",
  "terms.s11.h": "11. Applicable law",
  "terms.s11.p": "These terms are governed by Dutch law. Disputes will be submitted to the competent court in the Netherlands.",
  "terms.s12.emailLabel": "Email:",
  "terms.s12.h": "12. Contact",
  "terms.s12.p": "For questions about these terms, you can contact us:",
  "terms.s12.phoneLabel": "Phone:",
  "terms.s2.h": "2. Service description",
  "terms.s2.li1": "Manage their own calendar settings",
  "terms.s2.li2": "Configure appointment types",
  "terms.s2.li3": "Set availability schedules",
  "terms.s2.li4": "Set up automated booking processes",
  "terms.s2.p": "Our service provides a multi-tenant calendar booking platform where businesses can:",
  "terms.s3.h": "3. Account and registration",
  "terms.s3.li1": "Provide accurate and complete information during registration",
  "terms.s3.li2": "Keep your account information up to date",
  "terms.s3.li3": "Be responsible for all activities under your account",
  "terms.s3.li4": "Keep your password secure and not share it",
  "terms.s3.p": "To use our service, you must:",
  "terms.s4.a1": "Legitimate business activities",
  "terms.s4.a2": "Managing appointments and bookings",
  "terms.s4.a3": "Communication with customers about bookings",
  "terms.s4.b1": "Use the service for illegal activities",
  "terms.s4.b2": "Send spam or unwanted messages",
  "terms.s4.b3": "Attempt to hack or abuse the service",
  "terms.s4.b4": "Access other users' accounts without permission",
  "terms.s4.h": "4. Permitted use",
  "terms.s4.p1": "You may use our service for:",
  "terms.s4.p2": "It is not permitted to:",
  "terms.s5.h": "5. Data protection",
  "terms.s5.p": "We take data protection seriously. Your personal data is processed in accordance with our Privacy Policy and applicable privacy legislation, including GDPR.",
  "terms.s6.h": "6. Service availability",
  "terms.s6.p": "We strive to keep our service available 24/7, but cannot guarantee 100% uptime. Maintenance and updates may cause temporary service interruptions.",
  "terms.s7.h": "7. Payments and billing",
  "terms.s7.p": "Payment terms are specified in your subscription. All prices are exclusive of VAT unless otherwise stated. Payments are due according to the agreed payment terms.",
  "terms.s8.h": "8. Termination",
  "terms.s8.p": "You may cancel your account at any time. We reserve the right to suspend or terminate accounts for violation of these terms or abuse of the service.",
  "terms.s9.h": "9. Liability",
  "terms.s9.p": "Our liability is limited to the amount you have paid for the service in the 12 months preceding the claim. We are not liable for indirect or consequential damages.",
  "terms.title": "Terms of Service",
  "testimonials.badge": "Who it's for",
  "testimonials.subtitle": "From salons to clinics to studios: if you book appointments, the WhatsApp assistant fits right in.",
  "testimonials.titleAccent": "appointment business",
  "testimonials.titlePre": "Built for every",
  "whyus.cardBack.c1Content": "Your assistant answers on WhatsApp around the clock, so customers can book, reschedule or cancel at any hour, even when you are closed. Every request is captured instead of lost to a missed call or a full voicemail.",
  "whyus.cardBack.c1Title": "Always taking bookings",
  "whyus.cardBack.c2Content": "Customers book in the WhatsApp they already use every day, so there is nothing to download and no account to create. That lower threshold means more requests actually turn into booked appointments.",
  "whyus.cardBack.c2Title": "No app to install",
  "whyus.cardBack.c3Content": "While traditional booking methods take minutes or hours, our AI responds instantly to customer inquiries. This includes understanding context, checking availability, and confirming appointments - all in under 30 seconds on average.",
  "whyus.cardBack.c3Title": "30sec Average Response",
  "whyus.cardBack.c4Content": "Automatic WhatsApp reminders and one-tap rescheduling make it easy for customers to keep or move an appointment instead of just not turning up. Because people actually read WhatsApp, the reminders land where email often doesn't.",
  "whyus.cardBack.c4Title": "Reminders that cut no-shows",
  "whyus.caseDisclaimer.tag1": "6-12 month performance tracking",
  "whyus.caseDisclaimer.tag2": "Results vary by implementation",
  "whyus.caseDisclaimer.text": "Based on verified business performance data from in-depth case studies",
  "whyus.caseStudies.s1After": "WhatsApp automation handles bookings instantly 24/7. Staff focus on patient care instead of answering phones. Zero double bookings with real-time calendar sync.",
  "whyus.caseStudies.s1Before": "Receptionists spent 3+ hours daily playing phone tag - patients calling during busy hours, getting voicemail, calling back repeatedly. Manual appointment book checking during calls caused 2-3 minute holds. Double bookings happened weekly.",
  "whyus.caseStudies.s1Impl1": "24/7 WhatsApp booking bot with calendar integration",
  "whyus.caseStudies.s1Impl2": "Automated reminders 24h + 2h before appointments",
  "whyus.caseStudies.s1Impl3": "Instant confirmations with appointment details",
  "whyus.caseStudies.s1Impl4": "Easy rescheduling without calling office",
  "whyus.caseStudies.s1MobileAfter": "24/7 instant booking, zero phone tag, no scheduling conflicts.",
  "whyus.caseStudies.s1MobileBefore": "3hrs daily phone tag, manual scheduling, double bookings weekly.",
  "whyus.caseStudies.s1Quote": "Our staff used to spend half their day answering the same booking questions. Now they can focus on what matters - taking care of patients.",
  "whyus.caseStudies.s1Res1": "3 hours/day staff time saved on phone calls",
  "whyus.caseStudies.s1Res2": "50% reduction in no-shows with WhatsApp reminders",
  "whyus.caseStudies.s1Res3": "35% more bookings from after-hours availability",
  "whyus.caseStudies.s1Res4": "Zero double bookings with automated calendar sync",
  "whyus.caseStudies.s1Sector": "Healthcare & Medical",
  "whyus.caseStudies.s1Stat1": "75% less phone time",
  "whyus.caseStudies.s1Stat2": "50% fewer no-shows",
  "whyus.caseStudies.s1Stat3": "24/7 availability",
  "whyus.caseStudies.s2After": "WhatsApp booking captures clients anytime. Staff work uninterrupted. Revenue increased 45% from previously missed opportunities.",
  "whyus.caseStudies.s2Before": "Walk-in only policy caused 30+ minute wait times and lost customers. Staff interrupted treatments to answer booking calls. Lost 60% of calls during busy periods when stylists couldn't answer phones.",
  "whyus.caseStudies.s2Impl1": "Intelligent WhatsApp bot understanding beauty services",
  "whyus.caseStudies.s2Impl2": "Real-time stylist availability checking",
  "whyus.caseStudies.s2Impl3": "Automated appointment confirmations with prep instructions",
  "whyus.caseStudies.s2Impl4": "Smart reminder system reducing no-shows",
  "whyus.caseStudies.s2MobileAfter": "24/7 booking, no interruptions, 45% revenue increase.",
  "whyus.caseStudies.s2MobileBefore": "Walk-ins only, 30min waits, 60% missed calls during treatments.",
  "whyus.caseStudies.s2Quote": "Before, we lost so many clients who called during treatments and got no answer. Now WhatsApp works 24/7 and books them instantly.",
  "whyus.caseStudies.s2Res1": "4x more bookings from after-hours WhatsApp availability",
  "whyus.caseStudies.s2Res2": "65% reduction in time spent on phone bookings",
  "whyus.caseStudies.s2Res3": "40% fewer no-shows with personalized WhatsApp reminders",
  "whyus.caseStudies.s2Res4": "45% revenue increase from captured missed opportunities",
  "whyus.caseStudies.s2Sector": "Beauty & Wellness",
  "whyus.caseStudies.s2Stat1": "4x more after-hours bookings",
  "whyus.caseStudies.s2Stat2": "65% staff time savings",
  "whyus.caseStudies.s2Stat3": "40% fewer no-shows",
  "whyus.caseStudies.s3After": "WhatsApp bot handles complex scheduling instantly, syncing with attorney calendars and court dates. Clients book preferred times without phone tag.",
  "whyus.caseStudies.s3Before": "Consultation scheduling took 4-6 phone calls per client - attorney availability checks, court schedule conflicts, client callback loops. Receptionists spent 40% of their time on booking coordination.",
  "whyus.caseStudies.s3Impl1": "Advanced WhatsApp bot with attorney calendar integration",
  "whyus.caseStudies.s3Impl2": "Court schedule conflict checking",
  "whyus.caseStudies.s3Impl3": "Automated consultation prep and document requests",
  "whyus.caseStudies.s3Impl4": "Client portal links sent automatically",
  "whyus.caseStudies.s3MobileAfter": "Instant booking with calendar sync, no phone tag needed.",
  "whyus.caseStudies.s3MobileBefore": "4-6 calls per booking, 40% receptionist time on scheduling.",
  "whyus.caseStudies.s3Quote": "Legal scheduling is complex - court dates, attorney availability, client conflicts. WhatsApp automation handles it all instantly while we focus on cases.",
  "whyus.caseStudies.s3Res1": "85% faster consultation scheduling process",
  "whyus.caseStudies.s3Res2": "3x higher client response rates vs phone calls",
  "whyus.caseStudies.s3Res3": "60% reduction in scheduling-related staff time",
  "whyus.caseStudies.s3Res4": "24/7 availability increasing bookings by 30%",
  "whyus.caseStudies.s3Sector": "Professional Services",
  "whyus.caseStudies.s3Stat1": "85% faster scheduling",
  "whyus.caseStudies.s3Stat2": "24/7 availability",
  "whyus.caseStudies.s3Stat3": "3x response rates",
  "whyus.caseStudies.s4After": "WhatsApp enables 24/7 booking with trainer availability sync. Automated reminders cut no-shows to under 10%. Revenue up 50% from better booking capture.",
  "whyus.caseStudies.s4Before": "Phone bookings only during gym hours (6am-10pm). Clients forgot sessions without reminders. Manual scheduling caused trainer conflicts. Lost revenue from missed calls during training sessions.",
  "whyus.caseStudies.s4Impl1": "Smart WhatsApp bot with trainer schedule integration",
  "whyus.caseStudies.s4Impl2": "Automatic session reminders with prep tips",
  "whyus.caseStudies.s4Impl3": "Easy session rescheduling without phone calls",
  "whyus.caseStudies.s4Impl4": "Payment links and membership renewals via chat",
  "whyus.caseStudies.s4MobileAfter": "24/7 booking, auto reminders, conflict-free scheduling, 50% revenue boost.",
  "whyus.caseStudies.s4MobileBefore": "Limited phone hours, forgotten sessions, trainer conflicts, missed calls.",
  "whyus.caseStudies.s4Quote": "Personal training relies on consistent sessions. WhatsApp reminders and easy rescheduling keep clients engaged and trainers' calendars full.",
  "whyus.caseStudies.s4Res1": "50% increase in personal training session bookings",
  "whyus.caseStudies.s4Res2": "90% reduction in no-shows with WhatsApp reminders",
  "whyus.caseStudies.s4Res3": "24/7 booking availability vs 16 hours phone coverage",
  "whyus.caseStudies.s4Res4": "Zero scheduling conflicts with automated calendar sync",
  "whyus.caseStudies.s4Sector": "Fitness & Training",
  "whyus.caseStudies.s4Stat1": "50% more PT sessions",
  "whyus.caseStudies.s4Stat2": "24/7 booking",
  "whyus.caseStudies.s4Stat3": "90% less no-shows",
