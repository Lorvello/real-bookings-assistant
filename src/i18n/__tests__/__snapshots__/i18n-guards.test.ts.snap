  "pricing.plans.enterprise.features.f6.text": "Advanced reputation management & review analytics",
  "pricing.plans.enterprise.features.f6.tooltip": "Monitor and manage online reviews across Google, Facebook, and other platforms with automated response suggestions and reputation scoring",
