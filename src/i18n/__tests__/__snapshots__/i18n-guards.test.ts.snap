  "pricing.plans.enterprise.description": "Complete business solution with dedicated WhatsApp number and premium support",
  "pricing.plans.enterprise.features.f1.text": "Complete professional suite included",
  "pricing.plans.enterprise.features.f1.tooltip": "All Professional plan features plus enterprise-grade capabilities",
  "pricing.plans.enterprise.features.f2.text": "Unlimited enterprise user access management",
  "pricing.plans.enterprise.features.f2.tooltip": "Unlimited team members with advanced role management, department hierarchies, and granular permissions",
  "pricing.plans.enterprise.features.f3.text": "Dedicated WhatsApp Business API with custom branding",
