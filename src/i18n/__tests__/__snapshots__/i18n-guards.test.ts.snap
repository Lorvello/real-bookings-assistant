  "privacy.lastUpdated": "Last updated:",
  "privacy.s1.h": "1. Introduction",
  "privacy.s1.p": "We respect your privacy and are committed to protecting your personal data. This privacy policy explains how we collect, use, store and protect your data when you use our calendar booking service.",
  "privacy.s10.closing": "You also have the right to file a complaint with the Data Protection Authority if you believe we are not handling your data correctly.",
  "privacy.s10.dpoLabel": "Data Protection Officer:",
  "privacy.s10.emailLabel": "Email:",
  "privacy.s10.h": "10. Contact and questions",
  "privacy.s10.p": "For questions about this privacy policy or exercising your rights, you can contact us:",
  "privacy.s10.phoneLabel": "Phone:",
  "privacy.s10.privacyLabel": "Privacy inquiries:",
