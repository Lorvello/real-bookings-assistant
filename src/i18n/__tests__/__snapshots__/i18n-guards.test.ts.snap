  "privacy.s7.p": "We only retain your data as long as necessary for the purposes for which it was collected:",
  "privacy.s7.v1": "As long as your account is active",
  "privacy.s7.v2": "Up to 30 days after closure (unless legally required otherwise)",
  "privacy.s7.v3": "Up to 7 years for administrative purposes",
  "privacy.s7.v4": "Maximum 12 months",
  "privacy.s8.closing": "You can manage cookies through your browser settings, but this may affect functionality.",
  "privacy.s8.h": "8. Cookies and tracking",
  "privacy.s8.li1": "Remembering your preferences and login status",
  "privacy.s8.li2": "Analyzing website usage for improvements",
  "privacy.s8.li3": "Providing personalized user experience",
  "privacy.s8.p": "Our website uses cookies and similar technologies for:",
  "privacy.s9.h": "9. Changes to this privacy policy",
  "privacy.s9.p": "We may update this privacy policy from time to time. We will notify you of important changes via email or a prominent notice on our website. The date of the last change is always displayed at the top of this document.",
  "privacy.title": "Privacy Policy",
  "process.demoDescription": "Test our AI booking agent in this demo chat interface",
