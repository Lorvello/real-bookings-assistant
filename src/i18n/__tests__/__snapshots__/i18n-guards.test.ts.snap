  "terms.lastUpdated": "Last updated:",
  "terms.s1.h": "1. Acceptance of terms",
  "terms.s1.p": "By using our calendar booking service, you agree to these terms of service. If you do not agree to these terms, you may not use our service.",
  "terms.s10.h": "10. Changes",
  "terms.s10.p": "We reserve the right to modify these terms. Changes will take effect 30 days after notification via email or through our website.",
  "terms.s11.h": "11. Applicable law",
  "terms.s11.p": "These terms are governed by Dutch law. Disputes will be submitted to the competent court in the Netherlands.",
  "terms.s12.emailLabel": "Email:",
  "terms.s12.h": "12. Contact",
  "terms.s12.p": "For questions about these terms, you can contact us:",
  "terms.s12.phoneLabel": "Phone:",
  "terms.s2.h": "2. Service description",
  "terms.s2.li1": "Manage their own calendar settings",
  "terms.s2.li2": "Configure appointment types",
  "terms.s2.li3": "Set availability schedules",
  "terms.s2.li4": "Set up automated booking processes",
  "terms.s2.p": "Our service provides a multi-tenant calendar booking platform where businesses can:",
  "terms.s3.h": "3. Account and registration",
  "terms.s3.li1": "Provide accurate and complete information during registration",
  "terms.s3.li2": "Keep your account information up to date",
  "terms.s3.li3": "Be responsible for all activities under your account",
  "terms.s3.li4": "Keep your password secure and not share it",
  "terms.s3.p": "To use our service, you must:",
  "terms.s4.a1": "Legitimate business activities",
  "terms.s4.a2": "Managing appointments and bookings",
  "terms.s4.a3": "Communication with customers about bookings",
  "terms.s4.b1": "Use the service for illegal activities",
  "terms.s4.b2": "Send spam or unwanted messages",
  "terms.s4.b3": "Attempt to hack or abuse the service",
  "terms.s4.b4": "Access other users' accounts without permission",
  "terms.s4.h": "4. Permitted use",
  "terms.s4.p1": "You may use our service for:",
  "terms.s4.p2": "It is not permitted to:",
  "terms.s5.h": "5. Data protection",
  "terms.s5.p": "We take data protection seriously. Your personal data is processed in accordance with our Privacy Policy and applicable privacy legislation, including GDPR.",
  "terms.s6.h": "6. Service availability",
  "terms.s6.p": "We strive to keep our service available 24/7, but cannot guarantee 100% uptime. Maintenance and updates may cause temporary service interruptions.",
  "terms.s7.h": "7. Payments and billing",
  "terms.s7.p": "Payment terms are specified in your subscription. All prices are exclusive of VAT unless otherwise stated. Payments are due according to the agreed payment terms.",
  "terms.s8.h": "8. Termination",
  "terms.s8.p": "You may cancel your account at any time. We reserve the right to suspend or terminate accounts for violation of these terms or abuse of the service.",
  "terms.s9.h": "9. Liability",
  "terms.s9.p": "Our liability is limited to the amount you have paid for the service in the 12 months preceding the claim. We are not liable for indirect or consequential damages.",
  "terms.title": "Terms of Service",
