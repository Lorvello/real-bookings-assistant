  "privacy.s5.tech3": "Regular security updates",
  "privacy.s5.tech4": "Access controls",
  "privacy.s5.techH": "Technical security:",
  "privacy.s6.h": "6. Your rights under GDPR",
  "privacy.s6.p": "As an EU resident, you have the following rights regarding your personal data:",
  "privacy.s6.r1h": "Right of access",
  "privacy.s6.r1p": "You can request a copy of all personal data we have about you",
  "privacy.s6.r2h": "Right to rectification",
  "privacy.s6.r2p": "You can request correction of incorrect or incomplete data",
  "privacy.s6.r3h": "Right to erasure",
  "privacy.s6.r3p": "You can request deletion of your personal data",
  "privacy.s6.r4h": "Right to data portability",
  "privacy.s6.r4p": "You can request your data in a machine-readable format",
