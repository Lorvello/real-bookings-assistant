  "hiw.results.heading": "Proven results that transform businesses",
  "hiw.results.learnMore": "Learn more",
  "hiw.results.stat1Detail": "Complete bookings from first message to confirmation in under 30 seconds. No phone calls, forms, or back-and-forth emails needed. Customers book instantly through familiar WhatsApp interface while you sleep.",
  "hiw.results.stat1Label": "Average booking time",
  "hiw.results.stat2Detail": "Businesses report 30-40% reductions in customer service costs while improving quality. Staff productivity increases 75% with 3x booking efficiency. 70% of inquiries handled without human intervention.",
  "hiw.results.stat2Label": "Reduction in service costs",
  "hiw.results.stat3Detail": "Companies like Tata CLiQ achieved 10x ROI generating $500k in WhatsApp sales monthly. 89% uplift in purchases per user, 72% higher sessions. 60-80% reduction in customer acquisition costs.",
  "hiw.results.stat3Label": "Return on investment potential",
  "hiw.results.stat4Detail": "Automated systems provide round-the-clock availability without staffing costs. 90% of users respond within 30 minutes vs 12-hour email response times. 42% higher 6-month retention rates.",
  "hiw.results.stat4Label": "Automated availability",
