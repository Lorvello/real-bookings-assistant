# Frontend (Vite) environment — public values only (these are bundled into the
# client, so NEVER put secrets here). Copy to .env and fill in. The real .env is
# git-ignored; server secrets live as Supabase edge-function secrets, not here.
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_WHATSAPP_NUMBER=+31600000000
